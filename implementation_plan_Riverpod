## Phase 5: Resume Reading + Last Visited Provider

### [NEW] `lib/providers/last_visited_provider.dart`

```dart
class LastVisitedEvent {
  final String id;
  final String title;
  final String? imageUrl;
  final String date;
  final String period;
  final String description;

  LastVisitedEvent({
    required this.id,
    required this.title,
    this.imageUrl,
    required this.date,
    required this.period,
    required this.description,
  });

  Map<String, dynamic> toJson() => { ... };
  factory LastVisitedEvent.fromJson(Map<String, dynamic> json) => ...;
}

class LastVisitedNotifier extends StateNotifier<LastVisitedEvent?> {
  LastVisitedNotifier() : super(null) { _load(); }

  Future<void> _load() async {
    final prefs = await SharedPreferences.getInstance();
    final json = prefs.getString('last_visited_event');
    if (json != null) {
      state = LastVisitedEvent.fromJson(jsonDecode(json));
    }
  }

  Future<void> save(LastVisitedEvent event) async {
    state = event;
    final prefs = await SharedPreferences.getInstance();
    await prefs.setString('last_visited_event', jsonEncode(event.toJson()));
  }
}

final lastVisitedProvider =
    StateNotifierProvider<LastVisitedNotifier, LastVisitedEvent?>((ref) {
  return LastVisitedNotifier();
});
```

