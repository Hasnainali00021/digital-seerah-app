## Phase 4: Timeline Provider

### [NEW] `lib/providers/timeline_provider.dart`

```dart
final timelineProvider = FutureProvider<List<Map<String, dynamic>>>((ref) async {
  final response = await Supabase.instance.client
      .from('timeline_events')
      .select()
      .order('order_index', ascending: true);
  return List<Map<String, dynamic>>.from(response);
});

// Category filter state
final selectedCategoryProvider = StateProvider<String>((ref) => 'All');

// Search query state
final searchQueryProvider = StateProvider<String>((ref) => '');

// Derived: filtered events
final filteredTimelineProvider = Provider<AsyncValue<List<Map<String, dynamic>>>>((ref) {
  final eventsAsync = ref.watch(timelineProvider);
  final category = ref.watch(selectedCategoryProvider);
  final query = ref.watch(searchQueryProvider).toLowerCase().trim();

  return eventsAsync.whenData((events) {
    return events.where((event) {
      final matchesCategory = category == 'All' || event['category'] == category;
      final title = (event['title'] ?? '').toString().toLowerCase();
      final desc = (event['short_description'] ?? '').toString().toLowerCase();
      final matchesSearch = query.isEmpty || title.contains(query) || desc.contains(query);
      return matchesCategory && matchesSearch;
    }).toList();
  });
});
```

